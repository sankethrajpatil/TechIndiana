# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# MONGODB_URI: Connection string for your MongoDB database.
MONGODB_URI="mongodb://localhost:27017/techindiana"

# FIREBASE_SERVICE_ACCOUNT_JSON: The full JSON string of your Firebase Service Account key.
# This is required for server-side authentication with Firebase Admin SDK.
FIREBASE_SERVICE_ACCOUNT_JSON='{"type": "service_account", ...}'

# EMAIL_USER: The email address used to send session summaries.
EMAIL_USER="your-email@gmail.com"
# EMAIL_PASS: The password or app password for the email account.
EMAIL_PASS="your-app-password"
