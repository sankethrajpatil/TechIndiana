# Database
MONGODB_URI=
MONGODB_DB=

# Gemini / AI
GEMINI_API_KEY=

# Firebase Admin (preferred: base64-encoded service account JSON)
# Either set FIREBASE_SERVICE_ACCOUNT_BASE64 (base64 of the JSON) or
# FIREBASE_SERVICE_ACCOUNT_JSON (raw JSON string) or a filepath referenced by
# GOOGLE_APPLICATION_CREDENTIALS in production.
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT=

# Email (nodemailer)
EMAIL_USER=
EMAIL_PASS=

# Optional: Google service account file for Calendar API (if used)
GOOGLE_APPLICATION_CREDENTIALS=

# Client-only envs (prefixed with VITE_ to expose to the frontend)
VITE_API_BASE_URL=

# AI / Gemini
GEMINI_API_KEY=

# MongoDB
MONGODB_URI=
MONGODB_DB=

# Firebase Admin (server-side). Prefer base64-encoded JSON.
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT=

# Email (nodemailer)
EMAIL_USER=
EMAIL_PASS=
